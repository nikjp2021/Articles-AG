<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" width="1200" height="630">
  <defs>
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#451a03" />
      <stop offset="60%" stop-color="#78350f" />
      <stop offset="100%" stop-color="#9a3412" />
    </linearGradient>
    <radialGradient id="skyGlow" cx="50%" cy="0%" r="80%">
      <stop offset="0%" stop-color="#fdba74" stop-opacity="0.5" />
      <stop offset="100%" stop-color="#451a03" stop-opacity="0" />
    </radialGradient>
  </defs>
  
  <!-- Background Mars Sky -->
  <rect width="100%" height="100%" fill="url(#bgGrad)" />
  <rect width="100%" height="100%" fill="url(#skyGlow)" />
  
  <!-- Mars Landscape/Hills -->
  <path d="M 0,450 Q 250,400 500,480 T 1000,430 T 1200,460 L 1200,630 L 0,630 Z" fill="#7c2d12" opacity="0.9" />
  <path d="M 0,500 Q 350,460 700,520 T 1200,480 L 1200,630 L 0,630 Z" fill="#9a3412" opacity="0.95" />
  <path d="M 0,550 Q 450,520 900,560 L 1200,540 L 1200,630 L 0,630 Z" fill="#c2410c" />
  
  <!-- Geodesic Domes (Mars Colony) -->
  <g transform="translate(350, 480)">
    <!-- Main Dome -->
    <path d="M -80,0 A 80,80 0 0,1 80,0 Z" fill="#e2e8f0" fill-opacity="0.2" stroke="#cbd5e1" stroke-width="2" />
    <!-- Grid Lines on Dome -->
    <line x1="0" y1="-80" x2="0" y2="0" stroke="#cbd5e1" stroke-width="1" opacity="0.5" />
    <path d="M -56,-56 Q 0,-20 56,-56" fill="none" stroke="#cbd5e1" stroke-width="1" opacity="0.5" />
    <path d="M -76,-25 Q 0,-5 76,-25" fill="none" stroke="#cbd5e1" stroke-width="1" opacity="0.5" />
  </g>
  <g transform="translate(500, 500) scale(0.6)">
    <!-- Small Dome -->
    <path d="M -80,0 A 80,80 0 0,1 80,0 Z" fill="#e2e8f0" fill-opacity="0.15" stroke="#cbd5e1" stroke-width="2" />
    <line x1="0" y1="-80" x2="0" y2="0" stroke="#cbd5e1" stroke-width="1" opacity="0.5" />
  </g>
  
  <!-- Astronaut Standing -->
  <g transform="translate(850, 420) scale(0.8)">
    <!-- Suit Body -->
    <rect x="-15" y="40" width="30" height="70" rx="10" fill="#e2e8f0" />
    <!-- Helmet -->
    <circle cx="0" cy="18" r="20" fill="#cbd5e1" />
    <!-- Visor -->
    <path d="M -12,18 A 12,12 0 0,1 12,18 Z" fill="#0f172a" />
    <!-- Life Support Pack -->
    <rect x="-22" y="45" width="8" height="50" rx="3" fill="#94a3b8" />
    <!-- Legs -->
    <rect x="-12" y="110" width="10" height="40" rx="2" fill="#cbd5e1" />
    <rect x="2" y="110" width="10" height="40" rx="2" fill="#cbd5e1" />
  </g>
  
  <!-- Outer Border (Threads Design) -->
  <rect x="20" y="20" width="1160" height="590" rx="15" fill="none" stroke="#000000" stroke-width="2" stroke-dasharray="10 5" opacity="0.6" />
  
  <!-- Text Content -->
  <text x="50%" y="100" dominant-baseline="middle" text-anchor="middle" font-family="'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif" font-size="36" font-weight="800" fill="#ffffff" letter-spacing="1">
    THREADS ENRICHMENT ASSET
  </text>
  <text x="50%" y="150" dominant-baseline="middle" text-anchor="middle" font-family="'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif" font-size="20" font-weight="500" fill="#cbd5e1">
    Topic: Mars Geodesic Domes & Astronaut (Existential Backup Drive & Multi-Planetary Future)
  </text>
  
  <!-- Quota Exhaustion Label -->
  <rect x="420" y="200" width="360" height="40" rx="20" fill="#ef4444" fill-opacity="0.2" stroke="#ef4444" stroke-width="1" />
  <text x="50%" y="225" dominant-baseline="middle" text-anchor="middle" font-family="sans-serif" font-size="14" font-weight="700" fill="#fca5a5">
    RATE LIMIT FALLBACK PLACEHOLDER
  </text>
</svg>
