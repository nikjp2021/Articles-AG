<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" width="1200" height="630">
  <defs>
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#0b0f19" />
      <stop offset="100%" stop-color="#111827" />
    </linearGradient>
    <linearGradient id="glowGrad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#2563eb" stop-opacity="0.8" />
      <stop offset="100%" stop-color="#3b82f6" stop-opacity="0.2" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="100%" height="100%" fill="url(#bgGrad)" />
  
  <!-- Decorative Grid -->
  <path d="M 0,100 L 1200,100 M 0,200 L 1200,200 M 0,300 L 1200,300 M 0,400 L 1200,400 M 0,500 L 1200,500" stroke="#1f2937" stroke-width="1" />
  <path d="M 200,0 L 200,630 M 400,0 L 400,630 M 600,0 L 600,630 M 800,0 L 800,630 M 1000,0 L 1000,630" stroke="#1f2937" stroke-width="1" />
  
  <!-- Glow Effect -->
  <circle cx="600" cy="315" r="300" fill="url(#glowGrad)" filter="blur(40px)" opacity="0.3" />
  
  <!-- Outer Border -->
  <rect x="20" y="20" width="1160" height="590" rx="15" fill="none" stroke="#2563eb" stroke-width="2" stroke-dasharray="10 5" opacity="0.6" />
  
  <!-- Icon Placeholder (Space/Sleek Craft) -->
  <g transform="translate(600, 240) scale(1.5)">
    <!-- Rocket/Spacecraft body -->
    <path d="M 0,-50 L 15,-10 L 25,20 L 0,10 L -25,20 L -15,-10 Z" fill="#3b82f6" />
    <!-- Jet Fire -->
    <path d="M -10,22 L 0,45 L 10,22 Z" fill="#ef4444" />
    <!-- Space Station / Earth Ring -->
    <ellipse cx="0" cy="-60" rx="40" ry="10" fill="none" stroke="#10b981" stroke-width="3" />
  </g>
  
  <!-- Text Content -->
  <text x="50%" y="420" dominant-baseline="middle" text-anchor="middle" font-family="'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif" font-size="36" font-weight="800" fill="#ffffff" letter-spacing="1">
    LINKEDIN ENRICHMENT ASSET
  </text>
  <text x="50%" y="470" dominant-baseline="middle" text-anchor="middle" font-family="'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif" font-size="20" font-weight="500" fill="#9ca3af">
    Topic: The Trillion-Dollar Frontier (Commercial Space Station & Spacecraft)
  </text>
  
  <!-- Quota Exhaustion Label -->
  <rect x="420" y="520" width="360" height="40" rx="20" fill="#ef4444" fill-opacity="0.2" stroke="#ef4444" stroke-width="1" />
  <text x="50%" y="545" dominant-baseline="middle" text-anchor="middle" font-family="sans-serif" font-size="14" font-weight="700" fill="#fca5a5">
    RATE LIMIT FALLBACK PLACEHOLDER
  </text>
</svg>
