<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" width="1200" height="630">
  <defs>
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#020617" />
      <stop offset="60%" stop-color="#0b1329" />
      <stop offset="100%" stop-color="#1e1b4b" />
    </linearGradient>
    <radialGradient id="sunGlow" cx="50%" cy="100%" r="60%">
      <stop offset="0%" stop-color="#f97316" stop-opacity="0.8" />
      <stop offset="40%" stop-color="#ea580c" stop-opacity="0.3" />
      <stop offset="100%" stop-color="#020617" stop-opacity="0" />
    </radialGradient>
  </defs>
  
  <!-- Background -->
  <rect width="100%" height="100%" fill="url(#bgGrad)" />
  <rect width="100%" height="100%" fill="url(#sunGlow)" opacity="0.6" />
  
  <!-- Water Waves / Horizon -->
  <path d="M 0,550 Q 300,540 600,550 T 1200,550 L 1200,630 L 0,630 Z" fill="#0f172a" opacity="0.9" />
  <path d="M 0,565 Q 400,555 800,565 T 1200,565 L 1200,630 L 0,630 Z" fill="#1e293b" opacity="0.5" />
  
  <!-- Drone Ship -->
  <rect x="450" y="530" width="300" height="30" rx="5" fill="#475569" stroke="#94a3b8" stroke-width="2" />
  <circle cx="600" cy="545" r="10" fill="none" stroke="#ef4444" stroke-width="3" />
  <line x1="480" y1="545" x2="720" y2="545" stroke="#94a3b8" stroke-width="1" />
  
  <!-- Outer Border -->
  <rect x="20" y="20" width="1160" height="590" rx="15" fill="none" stroke="#1877f2" stroke-width="2" stroke-dasharray="10 5" opacity="0.6" />
  
  <!-- Landing Rocket (Falcon style) -->
  <g transform="translate(600, 380) scale(1.2)">
    <!-- Rocket body -->
    <rect x="-10" y="-120" width="20" height="120" rx="2" fill="#e2e8f0" />
    <!-- Landing Legs -->
    <path d="M -10,0 L -30,20 L -25,0 Z" fill="#64748b" />
    <!-- Landing Legs Right -->
    <path d="M 10,0 L 30,20 L 25,0 Z" fill="#64748b" />
    <!-- Thruster Fire / Plume -->
    <path d="M -8,0 L 0,40 L 8,0 Z" fill="#f97316" />
    <path d="M -4,0 L 0,25 L 4,0 Z" fill="#facc15" />
  </g>
  
  <!-- Text Content -->
  <text x="50%" y="150" dominant-baseline="middle" text-anchor="middle" font-family="'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif" font-size="36" font-weight="800" fill="#ffffff" letter-spacing="1">
    FACEBOOK ENRICHMENT ASSET
  </text>
  <text x="50%" y="200" dominant-baseline="middle" text-anchor="middle" font-family="'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif" font-size="20" font-weight="500" fill="#9ca3af">
    Topic: Vertical Rocket Landing on Drone Ship (Cost Deflation & Reusable Tech)
  </text>
  
  <!-- Quota Exhaustion Label -->
  <rect x="420" y="250" width="360" height="40" rx="20" fill="#ef4444" fill-opacity="0.2" stroke="#ef4444" stroke-width="1" />
  <text x="50%" y="275" dominant-baseline="middle" text-anchor="middle" font-family="sans-serif" font-size="14" font-weight="700" fill="#fca5a5">
    RATE LIMIT FALLBACK PLACEHOLDER
  </text>
</svg>
