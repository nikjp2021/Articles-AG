<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1080 1080" width="1080" height="1080">
  <defs>
    <linearGradient id="spaceGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#020205" />
      <stop offset="40%" stop-color="#030712" />
      <stop offset="100%" stop-color="#080e26" />
    </linearGradient>
    <linearGradient id="earthGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#3b82f6" />
      <stop offset="50%" stop-color="#10b981" />
      <stop offset="100%" stop-color="#1e3a8a" />
    </linearGradient>
    <linearGradient id="atmosGlow" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#60a5fa" stop-opacity="1" />
      <stop offset="50%" stop-color="#3b82f6" stop-opacity="0.5" />
      <stop offset="100%" stop-color="#080e26" stop-opacity="0" />
    </linearGradient>
    <linearGradient id="cabinGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#1e293b" />
      <stop offset="100%" stop-color="#0f172a" />
    </linearGradient>
  </defs>
  
  <!-- Background Space -->
  <rect width="100%" height="100%" fill="url(#spaceGrad)" />
  
  <!-- Tiny Stars -->
  <circle cx="100" cy="150" r="1.5" fill="#ffffff" opacity="0.8" />
  <circle cx="250" cy="80" r="1" fill="#ffffff" opacity="0.5" />
  <circle cx="850" cy="200" r="2" fill="#ffffff" opacity="0.9" />
  <circle cx="950" cy="110" r="1.5" fill="#ffffff" opacity="0.6" />
  <circle cx="150" cy="400" r="1" fill="#ffffff" opacity="0.4" />
  <circle cx="880" cy="450" r="1.5" fill="#ffffff" opacity="0.7" />
  
  <!-- Earth Curvature -->
  <path d="M -100,800 Q 540,550 1180,800 L 1180,1180 L -100,1180 Z" fill="url(#earthGrad)" />
  <!-- Atmosphere Glow -->
  <path d="M -100,800 Q 540,545 1180,800" fill="none" stroke="url(#atmosGlow)" stroke-width="25" filter="blur(8px)" />
  
  <!-- Space Capsule Curved Window Frame (Interior View) -->
  <path d="M 0,0 L 1080,0 L 1080,1080 L 0,1080 Z M 100,100 A 450,450 0 0,0 980,100 A 450,450 0 0,0 980,980 A 450,450 0 0,0 100,980 Z" fill="url(#cabinGrad)" stroke="#334155" stroke-width="10" />
  
  <!-- Passenger Silhouette -->
  <g transform="translate(300, 500) scale(0.9)">
    <!-- Head -->
    <circle cx="200" cy="100" r="45" fill="#020617" />
    <!-- Shoulders & Back -->
    <path d="M 120,250 C 120,180 160,145 200,145 C 240,145 280,180 280,250 L 300,450 L 100,450 Z" fill="#020617" />
  </g>
  
  <!-- Decorative Instagram Outer Border -->
  <rect x="30" y="30" width="1020" height="1020" rx="40" fill="none" stroke="#db2777" stroke-width="3" stroke-dasharray="12 6" opacity="0.5" />
  
  <!-- Text Overlay inside Cabin -->
  <text x="50%" y="150" dominant-baseline="middle" text-anchor="middle" font-family="'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif" font-size="34" font-weight="900" fill="#ffffff" letter-spacing="1">
    INSTAGRAM ENRICHMENT ASSET
  </text>
  <text x="50%" y="210" dominant-baseline="middle" text-anchor="middle" font-family="'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif" font-size="20" font-weight="600" fill="#cbd5e1">
    Topic: Viewing Earth from Space Tourism Capsule
  </text>
  
  <!-- Quota Exhaustion Label -->
  <rect x="360" y="270" width="360" height="40" rx="20" fill="#ef4444" fill-opacity="0.2" stroke="#ef4444" stroke-width="1" />
  <text x="50%" y="295" dominant-baseline="middle" text-anchor="middle" font-family="sans-serif" font-size="14" font-weight="700" fill="#fca5a5">
    RATE LIMIT FALLBACK PLACEHOLDER
  </text>
</svg>
